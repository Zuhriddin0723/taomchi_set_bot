# =========================================
# Taomchi Set Bots - Environment Variables
# =========================================
# Bu faylni .env deb nomlang va haqiqiy tokenlarni kiriting.
# .env faylini hech qachon git'ga push qilmang!

# Telegram Bot Tokenlar
USER_BOT_TOKEN=your_user_bot_token_here
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# Ma'lumotlar bazasi fayli nomi
DB_NAME=database.db

# Admin Telegram ID lari (vergul bilan ajrating)
ALLOWED_ADMIN_IDS=1621989960,8529862654
